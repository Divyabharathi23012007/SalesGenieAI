# ---- Database Connection ----
# PostgreSQL database connection URL (SQLAlchemy compatible)
# Format: postgresql://username:password@hostname:port/database_name
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/salesgenie

# ---- LLM Configuration (Groq or OpenAI) ----
# To use Groq (Fast & Free Tier compatible):
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# To use OpenAI (Fallback if Groq is not set):
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ---- Network & Ports ----
# Host for the FastAPI server (default: 127.0.0.1)
FASTAPI_HOST=127.0.0.1
# Port for the FastAPI server (default: 8000)
FASTAPI_PORT=8000
# Complete URL of the FastAPI backend for Streamlit to contact
FASTAPI_URL=http://127.0.0.1:8000

# Port for the Streamlit frontend (default: 8502)
STREAMLIT_PORT=8502
