# pyenv
#   For a library or app, you might want to share your .python-version.
#   Comment/uncomment to suit your preference.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different platforms or python versions,
#   Pipfile.lock might be changed, and index partners can't build their clone.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock can be included or excluded, see:
#   https://python-poetry.org/docs/basic-usage/#commit-your-poetrylock-file-to-version-control
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock can be included or excluded, see:
#   https://pdm-project.org/en/latest/usage/project/#commit-the-lock-file
.pdm-python
.pdm-build/

# PEP 582; native support for Playgrounds in Python 3.8+
__pypackages__/

